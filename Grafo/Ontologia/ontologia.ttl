@prefix vini: <http://vini-eii.org/> .
@prefix rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl:  <http://www.w3.org/2002/07/owl#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .

#################################################################
# Ontología
#################################################################

vini:FootballOntology a owl:Ontology ;
    rdfs:label "VINI Football Knowledge Graph Ontology" ;
    rdfs:comment "Ontología para datos de fútbol: equipos, jugadores, partidos, estadísticas y eventos" .

#################################################################
# Clases
#################################################################

vini:Team a owl:Class .
vini:TeamSeason a owl:Class .
vini:Player a owl:Class .
vini:PlayerSeason a owl:Class .
vini:Game a owl:Class .
vini:GameStats a owl:Class .
vini:GamePerformance a owl:Class .
vini:GameBet a owl:Class .
vini:PlayerAppearance a owl:Class .
vini:Shot a owl:Class .
vini:Competition a owl:Class .
vini:CompetitionWinner a owl:Class .
vini:League a owl:Class .
vini:Season a owl:Class .
vini:Country a owl:Class .

#################################################################
# Relaciones
#################################################################

vini:hasSeason a owl:ObjectProperty ;
    rdfs:domain vini:Team ;
    rdfs:range vini:TeamSeason .

vini:hasSeason a owl:ObjectProperty ;
    rdfs:domain vini:Player ;
    rdfs:range vini:PlayerSeason .

vini:inSeason a owl:ObjectProperty ;
    rdfs:domain vini:TeamSeason ;
    rdfs:range vini:Season .

vini:inSeason a owl:ObjectProperty ;
    rdfs:domain vini:PlayerSeason ;
    rdfs:range vini:Season .

vini:playsFor a owl:ObjectProperty ;
    rdfs:domain vini:PlayerSeason ;
    rdfs:range vini:TeamSeason .

vini:hasPlayer a owl:ObjectProperty ;
    rdfs:domain vini:TeamSeason ;
    rdfs:range vini:PlayerSeason .

vini:born a owl:ObjectProperty ;
    rdfs:domain vini:Player ;
    rdfs:range vini:Country .

vini:playGame a owl:ObjectProperty ;
    rdfs:domain vini:TeamSeason ;
    rdfs:range vini:Game .

vini:hasStats a owl:ObjectProperty ;
    rdfs:domain vini:TeamSeason ;
    rdfs:range vini:GameStats .

vini:hasPerformance a owl:ObjectProperty ;
    rdfs:domain vini:TeamSeason ;
    rdfs:range vini:GamePerformance .

vini:game a owl:ObjectProperty ;
    rdfs:domain vini:GameStats ;
    rdfs:range vini:Game .

vini:game a owl:ObjectProperty ;
    rdfs:domain vini:GamePerformance ;
    rdfs:range vini:Game .

vini:team a owl:ObjectProperty ;
    rdfs:domain vini:GameStats ;
    rdfs:range vini:TeamSeason .

vini:team a owl:ObjectProperty ;
    rdfs:domain vini:GamePerformance ;
    rdfs:range vini:TeamSeason .

vini:hasBet a owl:ObjectProperty ;
    rdfs:domain vini:Game ;
    rdfs:range vini:GameBet .

vini:appearsIn a owl:ObjectProperty ;
    rdfs:domain vini:Player ;
    rdfs:range vini:PlayerAppearance .

vini:hasPlayerAppearance a owl:ObjectProperty ;
    rdfs:domain vini:Game ;
    rdfs:range vini:PlayerAppearance .

vini:hasShot a owl:ObjectProperty ;
    rdfs:domain vini:Game ;
    rdfs:range vini:Shot .

vini:hasShot a owl:ObjectProperty ;
    rdfs:domain vini:Player ;
    rdfs:range vini:Shot .

vini:assistedShot a owl:ObjectProperty ;
    rdfs:domain vini:Player ;
    rdfs:range vini:Shot .

vini:competition a owl:ObjectProperty ;
    rdfs:domain vini:CompetitionWinner ;
    rdfs:range vini:Competition .

vini:winningTeam a owl:ObjectProperty ;
    rdfs:domain vini:CompetitionWinner ;
    rdfs:range vini:Team .

vini:wonCompetition a owl:ObjectProperty ;
    rdfs:domain vini:Team ;
    rdfs:range vini:CompetitionWinner .

vini:wonBy a owl:ObjectProperty ;
    rdfs:domain vini:Competition ;
    rdfs:range vini:CompetitionWinner .

vini:playsInLeague a owl:ObjectProperty ;
    rdfs:domain vini:TeamSeason ;
    rdfs:range vini:League .

#################################################################
# Atributos
#################################################################

### TeamSeason

vini:name a owl:DatatypeProperty ;
    rdfs:domain vini:TeamSeason ;
    rdfs:range xsd:string .

vini:url a owl:DatatypeProperty ;
    rdfs:domain vini:TeamSeason ;
    rdfs:range xsd:string .

vini:formation a owl:DatatypeProperty ;
    rdfs:domain vini:TeamSeason ;
    rdfs:range xsd:string .

vini:overall a owl:DatatypeProperty ;
    rdfs:domain vini:TeamSeason ;
    rdfs:range xsd:integer .

vini:attack a owl:DatatypeProperty ;
    rdfs:domain vini:TeamSeason ;
    rdfs:range xsd:integer .

vini:midfield a owl:DatatypeProperty ;
    rdfs:domain vini:TeamSeason ;
    rdfs:range xsd:integer .

vini:defence a owl:DatatypeProperty ;
    rdfs:domain vini:TeamSeason ;
    rdfs:range xsd:integer .

vini:year a owl:DatatypeProperty ;
    rdfs:domain vini:TeamSeason ;
    rdfs:range xsd:gYear .

### Player

vini:name a owl:DatatypeProperty ;
    rdfs:domain vini:Player ;
    rdfs:range xsd:string .

vini:birth_year a owl:DatatypeProperty ;
    rdfs:domain vini:Player ;
    rdfs:range xsd:gYear .

vini:preferred_foot a owl:DatatypeProperty ;
    rdfs:domain vini:Player ;
    rdfs:range xsd:string .

### PlayerSeason

vini:age a owl:DatatypeProperty ;
    rdfs:domain vini:PlayerSeason ;
    rdfs:range xsd:integer .

vini:positions a owl:DatatypeProperty ;
    rdfs:domain vini:PlayerSeason ;
    rdfs:range xsd:string .

vini:overall_rating a owl:DatatypeProperty ;
    rdfs:domain vini:PlayerSeason ;
    rdfs:range xsd:integer .

vini:potential a owl:DatatypeProperty ;
    rdfs:domain vini:PlayerSeason ;
    rdfs:range xsd:integer .

vini:value a owl:DatatypeProperty ;
    rdfs:domain vini:PlayerSeason ;
    rdfs:range xsd:decimal .

vini:wage a owl:DatatypeProperty ;
    rdfs:domain vini:PlayerSeason ;
    rdfs:range xsd:decimal .

vini:year a owl:DatatypeProperty ;
    rdfs:domain vini:PlayerSeason ;
    rdfs:range xsd:gYear .

### Game

vini:date a owl:DatatypeProperty ;
    rdfs:domain vini:Game ;
    rdfs:range xsd:date .

vini:drawProbability a owl:DatatypeProperty ;
    rdfs:domain vini:Game ;
    rdfs:range xsd:decimal .

vini:year a owl:DatatypeProperty ;
    rdfs:domain vini:Game ;
    rdfs:range xsd:gYear .

### GameStats

vini:goals a owl:DatatypeProperty ;
    rdfs:domain vini:GameStats ;
    rdfs:range xsd:integer .

vini:xGoals a owl:DatatypeProperty ;
    rdfs:domain vini:GameStats ;
    rdfs:range xsd:decimal .

vini:shots a owl:DatatypeProperty ;
    rdfs:domain vini:GameStats ;
    rdfs:range xsd:integer .

vini:shotsOnTarget a owl:DatatypeProperty ;
    rdfs:domain vini:GameStats ;
    rdfs:range xsd:integer .

vini:result a owl:DatatypeProperty ;
    rdfs:domain vini:GameStats ;
    rdfs:range xsd:string .

### GamePerformance

vini:goals a owl:DatatypeProperty ;
    rdfs:domain vini:GamePerformance ;
    rdfs:range xsd:integer .

vini:probability a owl:DatatypeProperty ;
    rdfs:domain vini:GamePerformance ;
    rdfs:range xsd:decimal .

### PlayerAppearance

vini:goals a owl:DatatypeProperty ;
    rdfs:domain vini:PlayerAppearance ;
    rdfs:range xsd:integer .

vini:assists a owl:DatatypeProperty ;
    rdfs:domain vini:PlayerAppearance ;
    rdfs:range xsd:integer .

vini:yellowCard a owl:DatatypeProperty ;
    rdfs:domain vini:PlayerAppearance ;
    rdfs:range xsd:boolean .

vini:redCard a owl:DatatypeProperty ;
    rdfs:domain vini:PlayerAppearance ;
    rdfs:range xsd:boolean .

### Shot

vini:minute a owl:DatatypeProperty ;
    rdfs:domain vini:Shot ;
    rdfs:range xsd:integer .

vini:shotType a owl:DatatypeProperty ;
    rdfs:domain vini:Shot ;
    rdfs:range xsd:string .

vini:shotResult a owl:DatatypeProperty ;
    rdfs:domain vini:Shot ;
    rdfs:range xsd:string .

vini:xGoal a owl:DatatypeProperty ;
    rdfs:domain vini:Shot ;
    rdfs:range xsd:decimal .

### GameBet

vini:bettingHouse a owl:DatatypeProperty ;
    rdfs:domain vini:GameBet ;
    rdfs:range xsd:string .

vini:homeOdds a owl:DatatypeProperty ;
    rdfs:domain vini:GameBet ;
    rdfs:range xsd:decimal .

vini:drawOdds a owl:DatatypeProperty ;
    rdfs:domain vini:GameBet ;
    rdfs:range xsd:decimal .

vini:awayOdds a owl:DatatypeProperty ;
    rdfs:domain vini:GameBet ;
    rdfs:range xsd:decimal .